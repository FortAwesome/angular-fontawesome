{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./out-tsc/spec",
    "rootDir": "./",
    "types": ["jasmine"],
    "paths": {
      "@fortawesome/angular-fontawesome": ["./src/lib/public_api.ts"]
    }
  },
  "include": ["src/**/*.ts", "testing/**/*.ts"],
  "angularCompilerOptions": {
    "extendedDiagnostics": {
      "checks": {
        "nullishCoalescingNotNullable": "suppress",
        "optionalChainNotNullable": "suppress"
      }
    }
  }
}
